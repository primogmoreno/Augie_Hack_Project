{
  "name": "finlit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "concurrently --names \"backend,client\" --prefix-colors \"blue,cyan\" \"yarn backend\" \"yarn workspace finlit-client dev\"",
